# ============================================================================
#  Veritas — replication API keys (.env)
# ============================================================================
# Copy this file to `.env` and fill in your credentials.
#
#   cp .env.example .env
#   chmod 600 .env
#   $EDITOR .env
#
# These keys are passed into the replication container so that paper code
# (e.g. hypogenic, PaperBench-style runs) can call its own LLM APIs. Veritas's
# own agent providers authenticate via OAuth login or via API keys exported in
# your HOST shell (forwarded automatically). A provider API key placed in this
# file also works: keys of providers the run actually uses are exempted from
# phase-scoping. Note: with claude configured, an ANTHROPIC_API_KEY here
# reaches claude in every phase and billing follows the key.
#
# This file is read by `--env-file` at `./veritas replicate` and `./veritas
# shell`. Any line of the form `VAR=value` is exported to the container.
# Restrict to owner-only (chmod 600) since it holds raw secrets.

# ─── LLM provider keys ────────────────────────────────────────────────────
# OpenAI (gpt-4o, gpt-4o-mini, o1, o3 family)
# OPENAI_API_KEY=sk-...

# Anthropic (Claude API — independent of veritas's Claude Code OAuth)
# ANTHROPIC_API_KEY=sk-ant-...

# Google AI (Gemini API)
# GOOGLE_API_KEY=...

# OpenRouter (multi-model routing)
# OPENROUTER_API_KEY=sk-or-...

# ─── Data / experiment infrastructure ─────────────────────────────────────
# Hugging Face (gated models and datasets, e.g. Llama-2, ImageNet)
# HF_TOKEN=hf_...

# Weights & Biases (experiment tracking)
# WANDB_API_KEY=...

# ─── Add anything else your paper needs ───────────────────────────────────
# `--env-file` exports every uncommented `VAR=value` line, so any additional
# var you add here (e.g. GROQ_API_KEY, MISTRAL_API_KEY, TOGETHER_API_KEY,
# AWS credentials, etc.) is automatically available inside the container.

# ============================================================================
#  Veritas tunables (VERITAS_*) — override code defaults without editing code
# ============================================================================
# These are read by the Python pipeline (config_env.py). Resolution, highest
# wins: CLI flag (where one exists) → VERITAS_* env var → code default. Leave
# them commented to keep today's behavior; uncomment to tune. Bad values are
# logged and fall back to the default (never crash the run). Unlike the API
# keys above, these are not secrets.

# ─── Iterative manager loop ───────────────────────────────────────────────
# Hard cap on manager-driven retry iterations for the replicate phase.
#   1  = single-pass (loop OFF; identical to prior behavior; benchmark-comparable).
#   >1 = enable the post-replicate manager gate, which may re-run replication
#        with new instructions, bounded by this cap.
# Resolution (highest wins): `--max-iters` CLI flag → VERITAS_MAX_ITERS → 1.
# `./veritas replicate` with neither set stays single-pass, so the RB/CB harness
# outputs are unchanged. Set this (or pass --max-iters N) to opt into the loop.
# VERITAS_MAX_ITERS=3

# ─── Manager research sub-agents (Phase 3) ────────────────────────────────
# Cap on methodology/resource research sub-agent calls per manager iteration.
# These narrow searchers (resource-finder / literature-finder) only run inside
# the manager loop (VERITAS_MAX_ITERS > 1), on a `revise` with research_requests.
# Findings are redacted of reported values before reaching the replicate agent.
#   2 = default (allow up to one resource + one literature lookup per iteration).
#   0 = disable research even when the loop is on.
# VERITAS_RESEARCH_MAX_CALLS=2

# ─── Grading tolerances (deterministic verify, issue #56) ─────────────────
# Relative-error band for a numeric "match" (|rel err| <= this). Default 0.05.
# VERITAS_GRADE_MATCH_REL=0.05
# Relative-error band for a "partial" (|rel err| <= this). Default 0.30.
# VERITAS_GRADE_PARTIAL_REL=0.30
# Sigma band for a "match" when an uncertainty is given. Default 1.0.
# VERITAS_GRADE_SIGMA_MATCH=1.0
# Sigma band for a "partial" when an uncertainty is given. Default 2.0.
# VERITAS_GRADE_SIGMA_PARTIAL=2.0
# |paper value| below this switches to absolute comparison. Default 1e-9.
# VERITAS_GRADE_NEAR_ZERO_ABS=1e-9
# Absolute match band used when the paper value is ~0. Default 1e-6.
# VERITAS_GRADE_MATCH_ABS=1e-6
# Range/table overlap fraction required for a match. Default 0.80.
# VERITAS_GRADE_RANGE_OVERLAP_MATCH=0.80

# ─── Tier weights (Replication Score formula, issue #61) ──────────────────
# Weight of a headline-tier claim. Default 3.0.
# VERITAS_TIER_WEIGHT_HEADLINE=3.0
# Weight of a supporting-tier claim. Default 2.0.
# VERITAS_TIER_WEIGHT_SUPPORTING=2.0

# ─── Per-phase timeouts (seconds) ─────────────────────────────────────────
# Default for each phase when the matching CLI flag is absent. Unset = no
# timeout (the code default). The CLI flag (e.g. --analyze-timeout) wins.
# VERITAS_ANALYZE_TIMEOUT=
# VERITAS_CODEGEN_TIMEOUT=
# VERITAS_REPLICATE_TIMEOUT=
# VERITAS_VERIFY_TIMEOUT=
# VERITAS_EVALUATE_TIMEOUT=

# ─── Per-bucket engines (models) ──────────────────────────────────────────
# Default engine for each bucket when the matching CLI flag is absent, as
# [provider:]model (e.g. openrouter:openai/gpt-5.5 or a bare model name for
# the global provider). Unset = the provider CLI's own default model.
# The CLI flag (e.g. --verify-model) wins. Malformed values fail at startup.
# VERITAS_MODEL=
# VERITAS_ANALYZE_MODEL=
# VERITAS_CODEGEN_MODEL=
# VERITAS_REPLICATE_MODEL=
# VERITAS_ASSESS_MODEL=
# VERITAS_VERIFY_MODEL=
# VERITAS_EVALUATE_MODEL=
