#!/usr/bin/env bash
# =============================================================================
# veritas-host — run veritas directly on the host, no docker.
#
# For use on environments where docker is not available (HPC clusters,
# managed compute) but you still want the veritas pipeline. Assumes the
# host already has the runtime deps (claude/codex/gemini/opencode CLI,
# python, uv, pandoc/latex if you want PDF reports) on PATH.
#
# Mirrors the layout the docker `entrypoint.sh` would set up:
#   <--output>/veritas-skills/         (copy of templates/skills, runtime read-only)
#   <--output>/replication/codebase/   (writable copy of --repo, for the agent)
#   <--output>/replication/codebase.diff (generated on exit)
#   <--output>/.venv/                  (agent creates this; we just point at it)
#
# Usage: ./veritas-host replicate --paper x.pdf --repo ./code --output ./run-1
#        ./veritas-host replicate --paper x.pdf --output ./run-1 --mode paper-only
#        ./veritas-host report ./run-1
# =============================================================================

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERITAS_REPO="$SCRIPT_DIR"

# Tools we expect on PATH. We check up-front so the run doesn't fail
# mid-pipeline with a confusing error.
require_tools() {
    local missing=()
    for tool in "$@"; do
        if ! command -v "$tool" &> /dev/null; then
            missing+=("$tool")
        fi
    done
    if [ ${#missing[@]} -gt 0 ]; then
        echo "ERROR: missing required tools on PATH: ${missing[*]}" >&2
        echo "Install them and re-run. (claude/codex/gemini via curl|bash, opencode via npm, python+uv via your package manager.)" >&2
        exit 1
    fi
}

# Pull a flag value out of "$@" without consuming it. Used so we can
# pre-stage --output and --repo before handing the full argv to python.
# Args: <flag-name> <args...>
extract_flag() {
    local target="$1"; shift
    local prev=""
    for arg in "$@"; do
        if [ "$prev" = "$target" ]; then
            echo "$arg"
            return 0
        fi
        prev="$arg"
    done
}

# Extract --provider value from a subcommand's argv. Default: claude.
# Handles both `--provider X` and `--provider=X` forms. Mirrors
# extract_provider() in docker/run.sh so the host and docker paths agree
# on the default.
extract_provider() {
    local provider="claude"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --provider)
                [ $# -ge 2 ] || break
                provider="$2"; shift 2 ;;
            --provider=*) provider="${1#*=}"; shift ;;
            *) shift ;;
        esac
    done
    # Providers are case-insensitive throughout; canonicalize like the
    # Python layer does.
    printf '%s
' "$provider" | tr '[:upper:]' '[:lower:]'
}

# Bucket model flags whose engines this run can actually invoke, as far as
# the wrapper can tell: codegen runs only in paper-only mode, and the
# evaluate bucket only when an evaluation/citation/loop knob is on. Buckets
# left out are inert for the run — their engines must not be preflighted.
active_bucket_flags() {
    local has_paper="" has_repo="" mode="" evaluate=""
    [ -n "$VERITAS_MAX_ITERS" ] && evaluate=1
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --paper|--paper=*|-p) has_paper=1 ;;
            --repo|--repo=*|-r) has_repo=1 ;;
            --mode) [ $# -ge 2 ] && mode="$2" ;;
            --mode=*) mode="${1#*=}" ;;
            --evaluate|--check-citations|--max-iters|--max-iters=*) evaluate=1 ;;
        esac
        shift
    done
    if [ -z "$mode" ] || [ "$mode" = "auto" ]; then
        if [ -n "$has_paper" ] && [ -z "$has_repo" ]; then
            mode="paper-only"
        else
            mode="full"
        fi
    fi
    local flags="--analyze-model --replicate-model --assess-model --verify-model"
    [ "$mode" = "paper-only" ] && flags="$flags --codegen-model"
    [ -n "$evaluate" ] && flags="$flags --evaluate-model"
    echo "$flags"
}

# Explicit provider prefix of a bucket's model spec: the flag first, then the
# matching VERITAS_<BUCKET>_MODEL env var. Mirrors bucket_spec_provider() in
# docker/run.sh so the host and docker preflights agree. Empty when the
# bucket is unpinned or its spec carries no provider prefix.
bucket_spec_provider() {
    local flag="$1"; shift
    local spec=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            "$flag")
                [ $# -ge 2 ] || break
                spec="$2"; shift 2 ;;
            "$flag"=*) spec="${1#*=}"; shift ;;
            *) shift ;;
        esac
    done
    if [ -z "$spec" ]; then
        local var
        var="VERITAS_$(printf '%s' "${flag#--}" | tr 'a-z-' 'A-Z_')"
        spec="${!var}"
    fi
    spec=$(printf '%s' "$spec" | tr '[:upper:]' '[:lower:]')
    case "$spec" in
        claude:*|codex:*|gemini:*|openrouter:*) echo "${spec%%:*}" ;;
    esac
}

# Provider for a specific engine bucket: the pinned provider when the spec
# names one, else the global --provider.
extract_bucket_provider() {
    local flag="$1"; shift
    local pinned
    pinned=$(bucket_spec_provider "$flag" "$@")
    if [ -n "$pinned" ]; then
        echo "$pinned"
    else
        extract_provider "$@"
    fi
}

# Provider-aware tool preflight: the base tools passed as extra args are
# always required, plus the CLI of the provider that will be invoked.
require_provider_tools() {
    local provider="$1"; shift
    case "$provider" in
        claude|codex|gemini) require_tools "$@" "$provider" ;;
        openrouter)          require_tools "$@" opencode ;;
        *)
            echo "ERROR: unknown provider: $provider (expected claude|codex|gemini|openrouter)" >&2
            exit 1
            ;;
    esac
}

# Compute a comma-separated list of var names defined in $VERITAS_REPO/.env
# (uncommented `VAR=value` lines only). Empty string if .env is absent or
# defines no keys. Used to build VERITAS_ENV_FILE_KEYS — runner.py's
# _invoke_provider() reads this to know which env vars are user-supplied
# API keys, and only exposes them during the replicate phase (everything
# else strips them so analyze/plan/verify can't accidentally leak keys
# into transcripts). Mirrors compute_env_file_keys() in docker/run.sh.
compute_env_file_keys() {
    if [ ! -f "$VERITAS_REPO/.env" ]; then
        echo ""
        return
    fi
    grep -E '^[A-Za-z_][A-Za-z0-9_]*=' "$VERITAS_REPO/.env" 2>/dev/null \
        | sed 's/=.*//' \
        | tr '\n' ',' \
        | sed 's/,$//'
}

# "name, VRAM" per reachable GPU, semicolon-joined into one env-var-safe
# line, or empty if none (no GPU, or no reachable one). This IS the
# GPU-availability signal passed to the prompts — no separate boolean, since
# a bare yes/no doesn't tell codegen whether the paper's methodology
# actually fits in the available VRAM. Mirrors get_gpu_info() in
# docker/run.sh.
detect_gpu_info() {
    if command -v nvidia-smi &> /dev/null; then
        nvidia-smi --query-gpu=name,memory.total --format=csv,noheader 2>/dev/null \
            | tr '\n' ';' | sed 's/;$//'
    else
        echo ""
    fi
}

# Resolve --output to the same value veritas's config.py would compute.
# Mirrors the fallback chain at src/veritas/core/config.py:106-115.
resolve_output_dir() {
    local explicit_output paper_arg repo_arg
    explicit_output="$(extract_flag --output "$@")"
    if [ -n "$explicit_output" ]; then
        echo "$explicit_output"
        return 0
    fi
    repo_arg="$(extract_flag --repo "$@")"
    if [ -n "$repo_arg" ]; then
        echo "${repo_arg}/replicate"
        return 0
    fi
    paper_arg="$(extract_flag --paper "$@")"
    if [ -n "$paper_arg" ]; then
        echo "$(dirname "$paper_arg")/replicate"
        return 0
    fi
    echo "ERROR: cannot determine output dir: provide --output, --repo, or --paper" >&2
    return 1
}

# Invoke the veritas CLI with whatever Python actually has its deps.
# Preference order: an installed `veritas` on PATH (cluster default) -> the
# repo's own .venv -> `uv run` in the repo -> a bare `python -m` fallback. The
# bare fallback only runs on a host with none of the above, where it would have
# failed before too; the cluster path (veritas on PATH) is unchanged.
run_veritas_cli() {
    if command -v veritas &> /dev/null; then
        veritas "$@"
    elif [ -x "$VERITAS_REPO/.venv/bin/python" ]; then
        PYTHONPATH="$VERITAS_REPO/src${PYTHONPATH:+:$PYTHONPATH}" \
            "$VERITAS_REPO/.venv/bin/python" -m veritas.cli.main "$@"
    elif command -v uv &> /dev/null; then
        ( cd "$VERITAS_REPO" && uv run python -m veritas.cli.main "$@" )
    else
        PYTHONPATH="$VERITAS_REPO/src${PYTHONPATH:+:$PYTHONPATH}" \
            python -m veritas.cli.main "$@"
    fi
}

# -----------------------------------------------------------------------------
# Load .env values without executing the file: KEY=VALUE lines only, one pair
# of surrounding quotes stripped, comments and malformed lines skipped. An
# already-exported shell var wins (host environment beats .env, matching the
# docker wrapper), and values with spaces, #, or $ stay literal instead of
# breaking a `set -a` source.
# -----------------------------------------------------------------------------
load_env_file() {
    [ -f "$VERITAS_REPO/.env" ] || return 0
    chmod 600 "$VERITAS_REPO/.env" 2>/dev/null || true
    local line key val
    while IFS= read -r line || [ -n "$line" ]; do
        line="${line%$'\r'}"
        case "$line" in
            ''|\#*) continue ;;
        esac
        case "$line" in
            *=*) ;;
            *) continue ;;
        esac
        key="${line%%=*}"
        val="${line#*=}"
        case "$key" in
            [A-Za-z_]*) ;;
            *) continue ;;
        esac
        case "$key" in
            *[!A-Za-z0-9_]*) continue ;;
        esac
        case "$val" in
            \"*\") val="${val#\"}"; val="${val%\"}" ;;
            \'*\') val="${val#\'}"; val="${val%\'}" ;;
        esac
        if [ -z "${!key}" ]; then
            export "$key=$val"
        fi
    done < "$VERITAS_REPO/.env"
}

cmd_replicate() {
    # Tool check is provider-aware: python+uv are always needed, plus the
    # CLI of every provider a bucket resolves to — the global one unless
    # every bucket is explicitly pinned elsewhere, and each pinned one
    # (host mode has no image with all CLIs baked in).
    require_tools python uv
    # Engines pinned only in .env must be visible to the scan below
    # (load_env_file exports only unset vars, so re-running it later in
    # this function is a no-op).
    load_env_file
    local bucket_flag pinned unpinned="" seen=" "
    for bucket_flag in $(active_bucket_flags "$@"); do
        pinned=$(bucket_spec_provider "$bucket_flag" "$@")
        if [ -z "$pinned" ]; then
            unpinned=1
        elif [ "${seen#* $pinned }" = "$seen" ]; then
            seen="$seen$pinned "
            require_provider_tools "$pinned"
        fi
    done
    if [ -n "$unpinned" ]; then
        require_provider_tools "$(extract_provider "$@")"
    fi

    local output_dir
    output_dir="$(resolve_output_dir "$@")"
    output_dir="$(python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$output_dir")"
    mkdir -p "$output_dir"

    # Load $VERITAS_REPO/.env if present and set VERITAS_ENV_FILE_KEYS so
    # the Python runner scopes those vars per phase. Mirrors the docker
    # wrapper's `--env-file` + `-e VERITAS_ENV_FILE_KEYS=...` plumbing —
    # without this, papers that call OpenAI/Anthropic from inside their own
    # code would lose their keys silently on a cluster while working fine
    # in docker.
    if [ -f "$VERITAS_REPO/.env" ]; then
        load_env_file
        local keys
        keys="$(compute_env_file_keys)"
        if [ -n "$keys" ]; then
            export VERITAS_ENV_FILE_KEYS="$keys"
        fi
    else
        echo "Note: no .env found at $VERITAS_REPO/.env" >&2
        echo "      Papers that call LLM APIs (e.g. hypogenic, PaperBench) will fail without keys." >&2
        echo "      Run \`./veritas setup\` to configure (or copy .env.example to .env)." >&2
    fi

    # Stage skills catalog at <output>/veritas-skills. This mirrors the
    # Dockerfile's `cp -a /app/templates/skills /workspace/veritas-skills`
    # — runtime sees a copy, never the veritas source, so the agent has
    # nothing to gain by wandering into the veritas checkout.
    local skills_src="$VERITAS_REPO/templates/skills"
    local skills_dst="$output_dir/veritas-skills"
    if [ -d "$skills_src" ]; then
        if [ ! -d "$skills_dst" ]; then
            cp -a "$skills_src" "$skills_dst"
        fi
    else
        echo "WARNING: skills catalog not found at $skills_src — agent will see an empty path" >&2
    fi

    # Stage writable codebase copy at <output>/replication/codebase. This
    # mirrors the entrypoint.sh `cp -a /workspace/repo /workspace/output/replication/codebase`.
    # Skipped in paper-only mode (codegen writes the codebase from scratch)
    # and skipped if --repo wasn't provided.
    local repo_arg mode_arg
    repo_arg="$(extract_flag --repo "$@")"
    mode_arg="$(extract_flag --mode "$@")"
    local codebase_dst="$output_dir/replication/codebase"
    if [ -n "$repo_arg" ] && [ "$mode_arg" != "paper-only" ]; then
        if [ ! -d "$codebase_dst" ] || [ -z "$(ls -A "$codebase_dst" 2>/dev/null)" ]; then
            mkdir -p "$codebase_dst"
            cp -a "$repo_arg"/. "$codebase_dst"/
        fi
    fi

    # Diff trap: on exit, write codebase.diff against the original. Matches
    # the docker entrypoint's EXIT trap (entrypoint.sh:107-115). Runs in
    # subshell so cleanup doesn't disturb the caller's shell state.
    if [ -n "$repo_arg" ] && [ "$mode_arg" != "paper-only" ]; then
        trap "
            if [ -d '$codebase_dst' ]; then
                diff -ruN '$repo_arg' '$codebase_dst' \\
                    > '$output_dir/replication/codebase.diff' 2>/dev/null || true
            fi
        " EXIT
    elif [ "$mode_arg" = "paper-only" ]; then
        # Paper-only: codegen writes to codebase_dst from scratch. Diff
        # against an empty directory so the file lists everything created.
        # (`diff /dev/null <dir>` fails; an empty-dir anchor is portable.)
        local empty_anchor="$output_dir/.veritas/empty-anchor"
        mkdir -p "$empty_anchor"
        trap "
            if [ -d '$codebase_dst' ]; then
                diff -ruN '$empty_anchor' '$codebase_dst' \\
                    > '$output_dir/replication/codebase.diff' 2>/dev/null || true
            fi
            rmdir '$empty_anchor' 2>/dev/null || true
        " EXIT
    fi

    # Export the path env vars that prompt_generator.py reads (defaults
    # are docker paths; we override for host-side layout).
    export VERITAS_SKILLS_DIR="$skills_dst"
    export VERITAS_VENV_DIR="$output_dir/.venv"
    export VERITAS_GPU_INFO="$(detect_gpu_info)"

    run_veritas_cli replicate "$@"
}

cmd_passthrough() {
    # report / evaluate / estimate / check-citations — no pre/post staging
    # needed; load .env (provider keys + engine settings, host env wins)
    # and forward to the python CLI. VERITAS_ENV_FILE_KEYS keeps the
    # Python-side per-phase key scoping working for these entry points too.
    local subcmd="$1"; shift
    load_env_file
    local keys
    keys="$(compute_env_file_keys)"
    if [ -n "$keys" ]; then
        export VERITAS_ENV_FILE_KEYS="$keys"
    fi
    run_veritas_cli "$subcmd" "$@"
}

usage() {
    cat <<EOF
Usage: $(basename "$0") <subcommand> [args...]

Subcommands:
  full          Full pipeline: replicate + evaluate + report (the default; also via bare flags)
  replicate     Replication only, through verify (for benchmarking)
  estimate      Estimate compute/cost for a paper without running replication
  evaluate      Run the evaluation manager + report on an existing replicate dir
  report        Regenerate report from an existing replicate output dir
  check-citations  Verify the paper's references on an existing replicate dir

Same flags as the docker \`./veritas\` wrapper. The host wrapper:
  - copies templates/skills to <--output>/veritas-skills
  - copies --repo to <--output>/replication/codebase (full mode)
  - exports VERITAS_SKILLS_DIR, VERITAS_VENV_DIR, and VERITAS_GPU_INFO for prompt rendering
  - writes <--output>/replication/codebase.diff on exit
EOF
}

if [ $# -eq 0 ]; then
    usage
    exit 1
fi

case "$1" in
    full)
        shift
        cmd_replicate --evaluate "$@"
        ;;
    replicate)
        shift
        cmd_replicate "$@"
        ;;
    estimate)
        cmd_passthrough "$@"
        ;;
    report|evaluate)
        cmd_passthrough "$@"
        ;;
    check-citations)
        # The citation passes are LLM calls riding the evaluate bucket; fail
        # fast when that engine's CLI is missing, matching the docker
        # wrapper's credential preflight. Engines pinned only in .env count.
        load_env_file
        require_provider_tools "$(extract_bucket_provider --evaluate-model "$@")" python
        cmd_passthrough "$@"
        ;;
    -h|--help|help)
        usage
        ;;
    -*)
        # Bare invocation with inputs (first arg is a flag) → full pipeline.
        cmd_replicate --evaluate "$@"
        ;;
    *)
        echo "ERROR: unknown subcommand: $1" >&2
        usage
        exit 1
        ;;
esac
